    "items": [
      { "question": "What is schema markup?", "answer": "Schema markup is structured data vocabulary that helps search engines understand your content and display rich snippets in search results." },
      { "question": "Does schema markup improve SEO?", "answer": "Schema markup does not directly improve rankings, but it enables rich snippets which can increase click-through rates and visibility in search results." },
      { "question": "What is JSON-LD?", "answer": "JSON-LD (JavaScript Object Notation for Linked Data) is Google's recommended format for structured data. It is easy to implement and maintain." },
      { "question": "What schema types are most common?", "answer": "Common schema types include Article, Product, FAQ, LocalBusiness, Recipe, Event, Review, SoftwareApplication, and BreadcrumbList." }
